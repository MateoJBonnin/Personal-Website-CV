---
import { name, cvData } from '../data/cvData';

// Flatten arrays dynamically to create the unified Bento Box
const enSkills = [
    ...(cvData.en.techSkills.engines || []), 
    ...(cvData.en.techSkills.languages || []), 
    ...(cvData.en.techSkills.software || [])
];

const esSkills = [
    ...(cvData.es.techSkills.engines || []), 
    ...(cvData.es.techSkills.languages || []), 
    ...(cvData.es.techSkills.software || [])
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{name} | Game Developer CV</title>
    <script is:inline>
        const savedTheme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', savedTheme);
        
        const savedLang = localStorage.getItem('lang') || 'en';
        document.documentElement.setAttribute('data-lang', savedLang);
    </script>
</head>
<body>

    <header class="profile-container">
        <div class="profile-pic-wrapper">
            <div class="profile-pic-crop">
                <img src="/profile.webp" alt={name} class="profile-pic" />
            </div>
        </div>
        <div class="header-text">
            <div class="header-top-row">
                <h1 class="gradient-text">{name}</h1>
                
                <div class="control-cluster">
                    <button id="hero-capture" class="control-btn" aria-label="Generate LinkedIn Hero Banner" title="Generate LinkedIn Thumbnail" style="display: none;">
                        <svg viewBox="0 0 24 24" style="width: 22px; height: 22px; fill: var(--text-color);"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 5H5l3.5-4.5z"/></svg>
                    </button>
                    <button id="lang-toggle" class="control-btn lang-btn" aria-label="Switch Language / Cambiar Idioma">
                        <span class="lang-en">ES</span>
                        <span class="lang-es">EN</span>
                    </button>
                    <button id="theme-toggle" class="control-btn" aria-label="Toggle light and dark mode">
                        <svg class="sun-icon" viewBox="0 0 24 24"><path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.41 0-1.41l-1.06-1.06zm-12.37 1.06l-1.06 1.06c-.39.39-.39 1.03 0 1.41.39.39 1.03.39 1.41 0l1.06-1.06c.39-.39.39-1.03 0-1.41s-1.03-.39-1.41 0zm12.37-13.43a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/></svg>
                        <svg class="moon-icon" viewBox="0 0 24 24"><path d="M12.3 2a10 10 0 0 0-1.9 19.8 10 10 0 0 0 11.5-11.5 10.3 10.3 0 0 1-9.6-8.3z"/></svg>
                    </button>
                </div>
            </div>
            
            <p class="subtitle lang-en"><strong>{cvData.en.title}</strong></p>
            <p class="subtitle lang-es"><strong>{cvData.es.title}</strong></p>
            
            <div class="print-links">
                https://mateojavierbonnin.netlify.app/ | https://github.com/MateoJBonnin | https://www.linkedin.com/in/mateojavierbonnin | mateojavierbonnin@gmail.com
            </div>
            
            <div class="icon-container">
                <a href="https://linkedin.com/in/mateojavierbonnin" target="_blank" class="icon-btn icon-linkedin" aria-label="LinkedIn Profile">
                    <svg viewBox="0 0 24 24"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
                </a>
                <a href="https://github.com/MateoJBonnin" target="_blank" class="icon-btn icon-github" aria-label="GitHub Profile">
                    <svg viewBox="0 0 24 24"><path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.07 2.91.83.1-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/></svg>
                </a>
                <a href="mailto:mateojavierbonnin@gmail.com" class="icon-btn icon-mail" aria-label="Send Email">
                    <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                </a>
            </div>
        </div>
    </header>

    <main>
        <section class="skills-grid">
            <div class="panel lang-en">
                <h2>{cvData.en.sections.skills}</h2>
                <div class="bento-container">
                    {enSkills.map(skill => (
                        <div class="bento-item">
                            <span class="bento-text">{skill}</span>
                        </div>
                    ))}
                </div>
            </div>

            <div class="panel lang-es">
                <h2>{cvData.es.sections.skills}</h2>
                <div class="bento-container">
                    {esSkills.map(skill => (
                        <div class="bento-item">
                            <span class="bento-text">{skill}</span>
                        </div>
                    ))}
                </div>
            </div>

            <div class="panel lang-en">
                <h2>{cvData.en.sections.languages}</h2>
                <div class="bento-container bento-lang-container">
                    {cvData.en.languages?.map(lang => (
                        <div class="bento-item bento-lang">
                            <span class="bento-text">{lang.name}</span>
                            <span class="bento-subtext">{lang.level}</span>
                        </div>
                    ))}
                </div>
            </div>

            <div class="panel lang-es">
                <h2>{cvData.es.sections.languages}</h2>
                <div class="bento-container bento-lang-container">
                    {cvData.es.languages?.map(lang => (
                        <div class="bento-item bento-lang">
                            <span class="bento-text">{lang.name}</span>
                            <span class="bento-subtext">{lang.level}</span>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section>
            <h2 class="lang-en">{cvData.en.sections.experience}</h2>
            <h2 class="lang-es">{cvData.es.sections.experience}</h2>
            
            <div class="experience-container lang-en">
                {cvData.en.experiences?.map((exp) => (
                    <div class="experience-item">
                        <div class="exp-header">
                            <div class="exp-title-group">
                                <h3><strong>{exp.company}</strong> <span class="divider">/</span> <em class="role-text">{exp.role}</em></h3>
                                {exp.modality && <span class="modality-tag">{exp.modality}</span>}
                            </div>
                            <span class="exp-date">{exp.date}</span>
                        </div>
                        {exp.tags && <div class="exp-keywords-row">{exp.tags.map(tag => <span class="keyword-chip">{tag}</span>)}</div>}
                        <ul class="exp-bullets">{exp.bullets.map((bullet) => <li>{bullet}</li>)}</ul>
                    </div>
                ))}
            </div>

            <div class="experience-container lang-es">
                {cvData.es.experiences?.map((exp) => (
                    <div class="experience-item">
                        <div class="exp-header">
                            <div class="exp-title-group">
                                <h3><strong>{exp.company}</strong> <span class="divider">/</span> <em class="role-text">{exp.role}</em></h3>
                                {exp.modality && <span class="modality-tag">{exp.modality}</span>}
                            </div>
                            <span class="exp-date">{exp.date}</span>
                        </div>
                        {exp.tags && <div class="exp-keywords-row">{exp.tags.map(tag => <span class="keyword-chip">{tag}</span>)}</div>}
                        <ul class="exp-bullets">{exp.bullets.map((bullet) => <li>{bullet}</li>)}</ul>
                    </div>
                ))}
            </div>
        </section>

        <section>
            <h2 class="lang-en">{cvData.en.sections.projects}</h2>
            <h2 class="lang-es">{cvData.es.sections.projects}</h2>
            
            <div class="projects-container lang-en">
                {cvData.en.projects?.map((project) => (
                    <div class="project-card">
                        <div class="project-info">
                            <div>
                                <h3>{project.title} <span class="tech-tag">{project.tech}</span></h3>
                                <ul class="proj-bullets">{project.bullets.map((bullet) => <li>{bullet}</li>)}</ul>
                            </div>
                            {project.links && (
                                <div class="project-links-row">
                                    {project.links.map(link => (
                                        <a href={link.url} class="store-btn" target="_blank">
                                            {link.type === 'steam' && <svg class="platform-icon" viewBox="0 0 90.321 90.473"><path d="M45.084 1c-23.238 0-42.275 17.918-44.084 40.689l23.71 9.803c2.009-1.374 4.436-2.179 7.047-2.179.234 0 .467.01.698.021l10.544-15.283c0-.073 0-.144 0-.216 0-9.199 7.483-16.683 16.683-16.683 9.199 0 16.682 7.484 16.682 16.683s-7.483 16.684-16.682 16.684c-.127 0-.253 0-.379-.01l-15.038 10.73c.01.195.015.394.015.592 0 6.906-5.617-12.522-12.522 12.522-6.061 0-11.129-4.326-12.277-10.055l-16.957-7.006c5.25 18.568 22.309 32.181 42.56 32.181 24.432 0 44.237-19.806 44.237-44.235 0-24.433-19.806-44.238-44.237-44.238M28.721 68.122l-5.434-2.245c.963 2.005 2.629 3.684 4.841 4.606 4.782 1.992 10.295-.277 12.288-5.063.965-2.314.971-4.869.014-7.189-.955-2.321-2.757-4.131-5.074-5.097-2.299-.957-4.762-.922-6.926-.105l5.613 2.321c3.527 1.47 5.195 5.52 3.725 9.047-1.467 3.528-5.52 5.196-9.047 3.725M70.796 33.835c0-6.129-4.986-11.116-11.116-11.116-6.129 0-11.116 4.987-11.116 11.116 0 6.13 4.987 11.115 11.116 11.115 6.13 0 11.116-4.986 11.116-11.115m-19.448-.019c0-4.612 3.739-8.35 8.351-8.35s8.351 3.738 8.351 8.35-3.739 8.35-8.351 8.35-8.351-3.739-8.351-8.35"/></svg>}
                                            {link.type === 'appstore' && <svg class="platform-icon" viewBox="0 0 384 512"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>}
                                            {link.type === 'playstore' && <svg class="platform-icon" viewBox="0 0 512 512"><path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.2-60.8zM104.6 499l280.8-161.2-60.1-60.1L104.6 499z"/></svg>}
                                            {link.type === 'website' && <svg class="platform-icon" viewBox="0 0 24 24"><path d="M14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3m-2 16H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7z"/></svg>}
                                            {link.type === 'itch' && <svg class="platform-icon" viewBox="0 0 245.37069 220.73612"><path d="M31.99 1.365C21.287 7.72.2 31.945 0 38.298v10.516C0 62.144 12.46 73.86 23.773 73.86c13.584 0 24.902-11.258 24.903-24.62 0 13.362 10.93 24.62 24.515 24.62 13.586 0 24.165-11.258 24.165-24.62 0 13.362 11.622 24.62 25.207 24.62h.246c13.586 0 25.208-11.258 25.208-24.62 0 13.362 10.58 24.62 24.164 24.62 13.585 0 24.515-11.258 24.515-24.62 0 13.362 11.32 24.62 24.903 24.62 11.313 0 23.773-11.714 23.773-25.046V38.298c-.2-6.354-21.287-30.58-31.988-36.933C180.118.197 157.056-.005 122.685 0c-34.37.003-81.228.54-90.697 1.365zm65.194 66.217a28.025 28.025 0 0 1-4.78 6.155c-5.128 5.014-12.157 8.122-19.906 8.122a28.482 28.482 0 0 1-19.948-8.126c-1.858-1.82-3.27-3.766-4.563-6.032l-.006.004c-1.292 2.27-3.092 4.215-4.954 6.037a28.5 28.5 0 0 1-19.948 8.12c-.934 0-1.906-.258-2.692-.528-1.092 11.372-1.553 22.24-1.716 30.164l-.002.045c-.02 4.024-.04 7.333-.06 11.93.21 23.86-2.363 77.334 10.52 90.473 19.964 4.655 56.7 6.775 93.555 6.788h.006c36.854-.013 73.59-2.133 93.554-6.788 12.883-13.14 10.31-66.614 10.52-90.474-.022-4.596-.04-7.905-.06-11.93l-.003-.045c-.162-7.926-.623-18.793-1.715-30.165-.786.27-1.757.528-2.692.528a28.5 28.5 0 0 1-19.948-8.12c-1.862-1.822-3.662-3.766-4.955-6.037l-.006-.004c-1.294 2.266-2.705 4.213-4.563 6.032a28.48 28.48 0 0 1-19.947 8.125c-7.748 0-14.778-3.11-19.906-8.123a28.025 28.025 0 0 1-4.78-6.155 27.99 27.99 0 0 1-4.736 6.155 28.49 28.49 0 0 1-19.95 8.124c-.27 0-.54-.012-.81-.02h-.007c-.27.008-.54.02-.813.02a28.49 28.49 0 0 1-19.95-8.123 27.992 27.992 0 0 1-4.736-6.155zm-20.486 26.49l-.002.01h.015c8.113.017 15.32 0 24.25 9.746 7.028-.737 14.372-1.105 21.722-1.094h.006c7.35-.01 14.694.357 21.723 1.094 8.93-9.747 16.137-9.73 24.25-9.746h.014l-.002-.01c3.833 0 19.166 0 29.85 30.007L210 165.244c8.504 30.624-2.723 31.373-16.727 31.4-20.768-.773-32.267-15.855-32.267-30.935-11.496 1.884-24.907 2.826-38.318 2.827h-.006c-13.412 0-26.823-.943-38.318-2.827 0 15.08-11.5 30.162-32.267 30.935-14.004-.027-25.23-.775-16.726-31.4L46.85 124.08c10.684-30.007 26.017-30.007 29.85-30.007zm45.985 23.582v.006c-.02.02-21.863 20.08-25.79 27.215l14.304-.573v12.474c0 .584 5.74.346 11.486.08h.006c5.744.266 11.485.504 11.485-.08v-12.474l14.304.573c-3.928-7.135-25.79-27.215-25.79-27.215v-.006l-.003.002z"/></svg>}
                                            <span>{link.label}</span>
                                        </a>
                                    ))}
                                </div>
                            )}
                        </div>
                        <div class="project-media">
                            <div class="video-overlay"></div>
                            <div class="media-scroller">
                                {project.videoSrc && (
                                    <video class="media-item" autoplay loop muted playsinline>
                                        <source src={project.videoSrc} type="video/mp4" />
                                    </video>
                                )}
                                {project.images && project.images.map(img => (
                                    <img class="media-item" src={img} alt="Project media screenshot" loading="lazy" />
                                ))}
                            </div>
                            
                            {((project.images?.length > 1) || (project.videoSrc && project.images?.length > 0)) && (
                                <button class="scroll-btn" aria-label="Next media item">
                                    <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                                </button>
                            )}
                        </div>
                    </div>
                ))}
            </div>

            <div class="projects-container lang-es">
                {cvData.es.projects?.map((project) => (
                    <div class="project-card">
                        <div class="project-info">
                            <div>
                                <h3>{project.title} <span class="tech-tag">{project.tech}</span></h3>
                                <ul class="proj-bullets">{project.bullets.map((bullet) => <li>{bullet}</li>)}</ul>
                            </div>
                            {project.links && (
                                <div class="project-links-row">
                                    {project.links.map(link => (
                                        <a href={link.url} class="store-btn" target="_blank">
                                            {link.type === 'steam' && <svg class="platform-icon" viewBox="0 0 90.321 90.473"><path d="M45.084 1c-23.238 0-42.275 17.918-44.084 40.689l23.71 9.803c2.009-1.374 4.436-2.179 7.047-2.179.234 0 .467.01.698.021l10.544-15.283c0-.073 0-.144 0-.216 0-9.199 7.483-16.683 16.683-16.683 9.199 0 16.682 7.484 16.682 16.683s-7.483 16.684-16.682 16.684c-.127 0-.253 0-.379-.01l-15.038 10.73c.01.195.015.394.015.592 0 6.906-5.617-12.522-12.522 12.522-6.061 0-11.129-4.326-12.277-10.055l-16.957-7.006c5.25 18.568 22.309 32.181 42.56 32.181 24.432 0 44.237-19.806 44.237-44.235 0-24.433-19.806-44.238-44.237-44.238M28.721 68.122l-5.434-2.245c.963 2.005 2.629 3.684 4.841 4.606 4.782 1.992 10.295-.277 12.288-5.063.965-2.314.971-4.869.014-7.189-.955-2.321-2.757-4.131-5.074-5.097-2.299-.957-4.762-.922-6.926-.105l5.613 2.321c3.527 1.47 5.195 5.52 3.725 9.047-1.467 3.528-5.52 5.196-9.047 3.725M70.796 33.835c0-6.129-4.986-11.116-11.116-11.116-6.129 0-11.116 4.987-11.116 11.116 0 6.13 4.987 11.115 11.116 11.115 6.13 0 11.116-4.986 11.116-11.115m-19.448-.019c0-4.612 3.739-8.35 8.351-8.35s8.351 3.738 8.351 8.35-3.739 8.35-8.351 8.35-8.351-3.739-8.351-8.35"/></svg>}
                                            {link.type === 'appstore' && <svg class="platform-icon" viewBox="0 0 384 512"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>}
                                            {link.type === 'playstore' && <svg class="platform-icon" viewBox="0 0 512 512"><path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.2-60.8zM104.6 499l280.8-161.2-60.1-60.1L104.6 499z"/></svg>}
