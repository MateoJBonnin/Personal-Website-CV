                        </div>
                        <div class="project-media">
                            <div class="video-overlay"></div>
                            <div class="media-scroller">
                                {project.videoSrc && (
                                    <video class="media-item" autoplay loop muted playsinline>
                                        <source src={project.videoSrc} type="video/mp4" />
                                    </video>
                                )}
                                {project.images && project.images.map(img => (
                                    <img class="media-item" src={img} alt="Project media screenshot" loading="lazy" />
                                ))}
                            </div>
                            
                            {((project.images?.length > 1) || (project.videoSrc && project.images?.length > 0)) && (
                                <button class="scroll-btn" aria-label="Next media item">
                                    <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                                </button>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        </section>
    </main>

    <button class="download-btn lang-en" onclick="window.print()">{cvData.en.downloadBtn}</button>
    <button class="download-btn lang-es" onclick="window.print()">{cvData.es.downloadBtn}</button>

    <script>
        const themeBtn = document.getElementById('theme-toggle');
        themeBtn?.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const nextTheme = currentTheme === 'light' ? 'dark' : 'light';
            document.documentElement.setAttribute('data-theme', nextTheme);
            localStorage.setItem('theme', nextTheme);
        });

        const langBtn = document.getElementById('lang-toggle');
        langBtn?.addEventListener('click', () => {
            const currentLang = document.documentElement.getAttribute('data-lang');
            const nextLang = currentLang === 'en' ? 'es' : 'en';
            document.documentElement.setAttribute('data-lang', nextLang);
            localStorage.setItem('lang', nextLang);
        });

        document.addEventListener('click', (e) => {
            const btn = (e.target as HTMLElement).closest('.scroll-btn');
            if (!btn) return;
            
            const scroller = btn.parentElement?.querySelector('.media-scroller');
            if (scroller) {
                const width = scroller.clientWidth;
                if (scroller.scrollLeft + width >= scroller.scrollWidth - 15) {
                    scroller.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                    scroller.scrollBy({ left: width, behavior: 'smooth' });
                }
            }
        });

        // NEW: STEALTH DISCOVERY SYSTEM FOR GENERATOR BUTTON
        const heroBtn = document.getElementById('hero-capture');
        
        function evalStealthAccess() {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('debug') === 'true' || localStorage.getItem('debug-banner') === 'true') {
                if (heroBtn) heroBtn.style.display = 'flex';
            }
        }
        
        // Check triggers on load
        evalStealthAccess();

        // Hotkey activation: Ctrl + Shift + H (Toggles Button visibility anywhere)
        window.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.shiftKey && e.key.toLowerCase() === 'h') {
                e.preventDefault();
                if (heroBtn) {
                    const isHidden = heroBtn.style.display === 'none';
                    heroBtn.style.display = isHidden ? 'flex' : 'none';
                    localStorage.setItem('debug-banner', isHidden ? 'true' : 'false');
                }
            }
        });

        // HERO BANNER EXPORT CAPTURE LOGIC
        heroBtn?.addEventListener('click', async () => {
            const originalText = heroBtn.innerHTML;
            heroBtn.innerHTML = '...';
            heroBtn.style.pointerEvents = 'none';

            try {
                if (!(window as any).html2canvas) {
                    await new Promise((resolve, reject) => {
                        const script = document.createElement('script');
                        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
                        script.onload = resolve;
                        script.onerror = reject;
                        document.head.appendChild(script);
                    });
                }

                const currentLang = document.documentElement.getAttribute('data-lang') || 'en';
                const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';

                // Setup workspace wrapper targeting current preferences
                const canvasBox = document.createElement('div');
                canvasBox.setAttribute('data-theme', currentTheme);
                canvasBox.setAttribute('data-lang', currentLang);
                canvasBox.className = 'hero-landscape-workspace';

                const activeProfileNode = document.querySelector('.profile-container');
                if (!activeProfileNode) return;
                const profileClone = activeProfileNode.cloneNode(true) as HTMLElement;

                // Strip UI panels out of layout
                profileClone.querySelector('.control-cluster')?.remove();
                profileClone.querySelector('.icon-container')?.remove();

                // Build modern content columns
                const columnsLayout = document.createElement('div');
                columnsLayout.className = 'workspace-columns';

                const leftColumn = document.createElement('div');
                leftColumn.className = 'workspace-col-left';

                const rightColumn = document.createElement('div');
                rightColumn.className = 'workspace-col-right';

                // Extract Skills Group
                const skillsGroupSource = document.querySelector(`.panel.lang-${currentLang} .bento-container`);
                const skillsGroupLabel = document.querySelector(`.skills-grid .panel.lang-${currentLang} h2`)?.textContent || 'Skills';
                if (skillsGroupSource) {
                    const groupContainer = document.createElement('div');
                    groupContainer.className = 'workspace-section-card';
                    const title = document.createElement('h3');
                    title.textContent = skillsGroupLabel;
                    groupContainer.appendChild(title);
                    groupContainer.appendChild(skillsGroupSource.cloneNode(true));
                    leftColumn.appendChild(groupContainer);
                }

                // Extract Spoken Languages Bento Cards
                const languagesSource = document.querySelector(`.panel.lang-${currentLang} .bento-lang-container`);
                const languagesLabel = document.querySelector(`.skills-grid .panel.lang-${currentLang}:nth-of-type(3) h2, .skills-grid .panel.lang-${currentLang}:nth-of-type(4) h2`)?.textContent || 'Languages';
                if (languagesSource) {
                    const groupContainer = document.createElement('div');
                    groupContainer.className = 'workspace-section-card';
                    const title = document.createElement('h3');
                    title.textContent = languagesLabel;
                    groupContainer.appendChild(title);
                    groupContainer.appendChild(languagesSource.cloneNode(true));
                    leftColumn.appendChild(groupContainer);
                }

                // Extract Featured Projects titles + stack tags elegantly
                const projectCards = document.querySelectorAll(`.projects-container.lang-${currentLang} .project-card`);
                if (projectCards.length > 0) {
                    const projectsSection = document.createElement('div');
                    projectsSection.className = 'workspace-section-card full-height';
                    
                    const projectsHeader = document.createElement('h3');
                    projectsHeader.textContent = currentLang === 'es' ? 'Proyectos Destacados' : 'Featured Projects';
                    projectsSection.appendChild(projectsHeader);

                    const projectsListWrapper = document.createElement('div');
                    projectsListWrapper.className = 'workspace-projects-list';

                    // Map down top projects to preserve canvas sizing limits safely
                    Array.from(projectCards).slice(0, 2).forEach(card => {
                        const originalHeader = card.querySelector('h3');
                        if (originalHeader) {
                            const compactItem = document.createElement('div');
                            compactItem.className = 'workspace-project-item';
                            compactItem.appendChild(originalHeader.cloneNode(true));
                            
                            // Keep basic bullet definitions clean & stripped
                            const originalBullets = card.querySelector('.proj-bullets');
                            if (originalBullets) {
                                const bulletClone = originalBullets.cloneNode(true) as HTMLElement;
                                if (bulletClone.children.length > 1) {
                                    while(bulletClone.children.length > 1) {
                                        bulletClone.removeChild(bulletClone.lastChild!);
                                    }
                                }
                                compactItem.appendChild(bulletClone);
                            }
                            projectsListWrapper.appendChild(compactItem);
                        }
                    });

                    projectsSection.appendChild(projectsListWrapper);
                    rightColumn.appendChild(projectsSection);
                }

                columnsLayout.appendChild(leftColumn);
                columnsLayout.appendChild(rightColumn);

                const innerWrapper = document.createElement('div');
                innerWrapper.className = 'workspace-inner';
                innerWrapper.appendChild(profileClone);
                innerWrapper.appendChild(columnsLayout);

                canvasBox.appendChild(innerWrapper);
                document.body.appendChild(canvasBox);

                // Safe operational yield delay
                await new Promise(r => setTimeout(r, 250));

                const capturedCanvas = await (window as any).html2canvas(canvasBox, {
                    useCORS: true,
                    allowTaint: true,
                    backgroundColor: currentTheme === 'dark' ? '#0b090c' : '#faf8fa',
                    scale: 2
                });

                const downloadAnchor = document.createElement('a');
                downloadAnchor.download = `GameDev_Hero_${name.replace(/\s+/g, '_')}_${currentLang}.png`;
                downloadAnchor.href = capturedCanvas.toDataURL('image/png');
                downloadAnchor.click();

                document.body.removeChild(canvasBox);
            } catch (err) {
                console.error("Hero generation failed:", err);
            } {
                heroBtn.innerHTML = originalText;
                heroBtn.style.pointerEvents = 'auto';
            }
        });
    </script>
</body>
</html>

<style is:global>
    :root[data-theme="dark"] {
        --bg-color: #0b090c;
        --text-color: #f3f0f5;
        --text-muted: #aaa3b0;
        --accent-color: #ff85a2;
        --accent-gradient: linear-gradient(135deg, #ff758f 0%, #d68cff 100%);
        --text-headline: #ffffff;
        --bg-prime: #141118;
        --bg-sec: #1c1822;
        --border-prime: rgba(255, 255, 255, 0.04);
        --border-sec: rgba(255, 117, 143, 0.15);
        --tag-bg: rgba(255, 117, 143, 0.07);
        --tag-text: #ffb3c1;
        --tag-text-muted: #c8b6ff;
        --keyword-bg: rgba(214, 140, 255, 0.05);
        --keyword-border: rgba(214, 140, 255, 0.12);
        --keyword-text: #e1b3ff;
        .sun-icon { display: block; fill: #aaa3b0; }
        .moon-icon { display: none; }
    }

    :root[data-theme="light"] {
        --bg-color: #faf8fa;
        --text-color: #38313d;
        --text-muted: #6e6475;
        --accent-color: #c026d3;
        --accent-gradient: linear-gradient(135deg, #db2777 0%, #9333ea 100%);
        --text-headline: #1e1724;
        --bg-prime: #ffffff;
        --bg-sec: #f4eff5;
        --border-prime: rgba(0, 0, 0, 0.06);
        --border-sec: rgba(219, 39, 119, 0.12);
        --tag-bg: rgba(219, 39, 119, 0.05);
        --tag-text: #be185d;
        --tag-text-muted: #6b21a8;
        --keyword-bg: rgba(147, 51, 234, 0.04);
        --keyword-border: rgba(147, 51, 234, 0.1);
        --keyword-text: #701a75;
        .sun-icon { display: none; }
        .moon-icon { display: block; fill: #6e6475; }
    }

    :root[data-lang="en"] .lang-es { display: none !important; }
    :root[data-lang="es"] .lang-en { display: none !important; }

    body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background-color: var(--bg-color);
        color: var(--text-color);
        max-width: 850px;
        margin: 60px auto;
        padding: 0 25px;
        font-size: 1.1rem;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    h1, h2, h3 { font-weight: 700; letter-spacing: -0.02em; }
    h2 { font-size: 1.6rem; color: var(--text-headline); border-bottom: 1px solid var(--border-prime); padding-bottom: 10px; margin-top: 50px; margin-bottom: 24px; }
    
    .gradient-text { font-size: 2.8rem; background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin: 0; }
    .subtitle { color: var(--text-muted); font-size: 1.25rem; margin: 6px 0 0 0; }
    a { color: var(--accent-color); text-decoration: none; transition: color 0.2s ease; }

    .profile-container { display: flex; align-items: center; gap: 40px; padding-bottom: 30px; }
    .profile-pic-wrapper { position: relative; border-radius: 50%; padding: 4px; background: var(--accent-gradient); }
    .profile-pic-crop { width: 160px; height: 160px; border-radius: 50%; overflow: hidden; display: block; background-color: var(--bg-prime); }
    .profile-pic { width: 100%; height: 100%; object-fit: cover; display: block; transform: scale(1.25); transform-origin: center center; }
    
    .header-text { flex: 1; }
    .header-top-row { display: flex; justify-content: space-between; align-items: center; }
    .print-links { display: none; } 

    .control-cluster { display: flex; gap: 10px; align-items: center; }
    .control-btn { background: var(--bg-prime); border: 1px solid var(--border-prime); width: 44px; height: 44px; border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; }
    .control-btn:hover { transform: scale(1.05); border-color: var(--accent-color); }
    .control-btn svg { width: 22px; height: 22px; }
    
    .lang-btn { font-size: 0.85rem; font-weight: 700; color: var(--text-muted); font-family: monospace; }
    .lang-btn:hover { color: var(--text-headline); }

    .icon-container { display: flex; gap: 12px; margin-top: 20px; }
    .icon-btn { display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 12px; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15); }
    :root[data-theme="dark"] .icon-btn { background: #221c28; border: 1.5px solid rgba(255, 255, 255, 0.14); }
    :root[data-theme="light"] .icon-btn { background: #ffffff; border: 1.5px solid rgba(0, 0, 0, 0.12); }
    .icon-btn svg { width: 22px; height: 22px; fill: var(--text-color); transition: fill 0.25s ease, transform 0.2s ease; }
    
    .icon-btn:hover { transform: translateY(-3px); box-shadow: 0 6px 15px rgba(0, 0, 0, 0.25); }
    .icon-linkedin:hover { border-color: #0a66c2 !important; background: #0a66c2 !important; }
    .icon-linkedin:hover svg { fill: #ffffff !important; }
    .icon-github:hover { border-color: var(--text-headline) !important; background: var(--text-headline) !important; }
    :root[data-theme="dark"] .icon-github:hover svg { fill: #000000 !important; }
    :root[data-theme="light"] .icon-github:hover svg { fill: #ffffff !important; }
    .icon-mail:hover { border-color: #db2777 !important; background: #db2777 !important; }
    .icon-mail:hover svg { fill: #ffffff !important; }

    .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; align-items: start; }
    .panel { padding: 30px; border-radius: 24px; display: flex; flex-direction: column; background: var(--bg-prime); border: 1px solid var(--border-prime); }
    .panel h2 { margin-top: 0; margin-bottom: 24px; border-bottom: 1px solid var(--border-prime); }
    
    .bento-container {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .bento-item {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px 18px;
        background: var(--tag-bg);
        border: 1px solid var(--border-sec);
        border-radius: 12px;
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s, border-color 0.2s;
        cursor: default;
    }

    .bento-item:hover {
        transform: translateY(-2px);
        border-color: var(--accent-color);
        box-shadow: 0 4px 12px rgba(255, 117, 143, 0.1);
    }

    .bento-text {
        color: var(--tag-text);
        font-weight: 600;
        font-size: 0.95rem;
    }

    .bento-lang {
        flex-direction: column;
        align-items: flex-start;
        gap: 2px;
        padding: 12px 18px;
    }
    
    .bento-lang .bento-text {
        color: var(--text-color);
        font-size: 1.05rem;
    }

    .bento-subtext {
        color: var(--tag-text-muted);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .experience-container { display: flex; flex-direction: column; gap: 24px; }
    .experience-item { padding: 32px; border-radius: 24px; border: 1px solid var(--border-prime); }
    .experience-item:nth-of-type(odd) { background-color: var(--bg-prime); }
    .experience-item:nth-of-type(even) { background-color: var(--bg-sec); }
    
    .exp-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; margin-bottom: 12px; }
    .exp-title-group { display: flex; flex-direction: column; align-items: flex-start; gap: 8px; flex: 1 1 auto; }
    .exp-title-group h3 { font-size: 1.3rem; margin: 0; display: flex; align-items: center; flex-wrap: wrap; gap: 8px; }
    
    .divider { color: var(--text-muted); margin: 0 4px; font-weight: 300; opacity: 0.7; }
    .role-text { color: var(--text-color); font-style: normal; font-weight: 600; }
    .exp-date { color: var(--text-muted); font-size: 0.95rem; font-weight: 500; white-space: nowrap; margin-top: 4px; }
    
    .modality-tag { 
        font-size: 0.72rem; 
        font-weight: 600; 
        font-style: normal; 
        text-transform: uppercase; 
        letter-spacing: 0.05em; 
        padding: 4px 10px; 
        border-radius: 6px; 
        cursor: default; 
        user-select: none; 
        display: inline-block;
    }
    :root[data-theme="dark"] .modality-tag {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #ffffff;
    }
    :root[data-theme="light"] .modality-tag {
        background: rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.15);
        color: var(--text-headline);
    }
    
    .exp-keywords-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 18px; margin-top: 2px; }
    .keyword-chip { font-size: 0.82rem; font-weight: 600; color: var(--keyword-text); background: var(--keyword-bg); padding: 4px 12px; border-radius: 8px; border: 1px solid var(--keyword-border); cursor: default; user-select: none; }
